@startuml speckit-activity
!theme plain
skinparam ActivityBackgroundColor #E8F4F8
skinparam ActivityBorderColor #333
skinparam SwimlaneTitleFontSize 12

|#LightBlue|RE|
start
:speckit.specify;
note right: spec.md, branch
if (Figma design?) then (yes)
  :speckit.figma-specify;
  note right: design.md
endif
:speckit.clarify;
note right: Refined spec
|#LightGreen|DEV|
:speckit.plan;
note right: plan.md, research.md,\ndata-model.md, quickstart.md
:speckit.tasks;
note right: tasks.md
:speckit.analyze;
note right: Consistency report
:speckit.implement;
note right: Codebase changes
|#LightYellow|QA|
if (design.md exists?) then (yes)
  :speckit.design-compliance;
endif
:speckit.testcases *(optional)*;
:speckit.testcontent *(optional)*;
:speckit.document *(optional)*;
stop
@enduml
