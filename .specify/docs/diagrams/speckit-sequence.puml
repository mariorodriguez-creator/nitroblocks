@startuml speckit-sequence
!theme plain
actor User
participant "speckit.specify" as specify
participant "speckit.figma-specify" as figma
participant "speckit.clarify" as clarify
participant "speckit.plan" as plan
participant "speckit.tasks" as tasks
participant "speckit.analyze" as analyze
participant "speckit.implement" as implement
participant "speckit.design-compliance" as dc
participant "speckit.testcases" as tc
participant "speckit.testcontent" as tcontent
participant "speckit.document" as doc

User -> specify : describe feature
specify --> User : spec.md, branch
opt Figma design
  User -> figma : extract design
  figma --> User : design.md
end
User -> clarify : refine spec
clarify --> User : refined spec.md
User -> plan : create plan
plan --> User : plan.md, research.md, data-model.md, quickstart.md
User -> tasks : break down
tasks --> User : tasks.md
User -> analyze : verify consistency
analyze --> User : report
User -> implement : implement
implement --> User : codebase changes
opt design.md exists
  User -> dc : design-compliance
  dc --> User : design-expectations.json, PASS/FAIL
end
opt QA optional
  User -> tc : testcases
  tc --> User : testcases.csv
  User -> tcontent : testcontent
  tcontent --> User : reference content
  User -> doc : document
  doc --> User : authoring guide
end
@enduml
